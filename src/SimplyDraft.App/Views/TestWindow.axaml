<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimplyDraft.App.ViewModels"
        xmlns:controls="using:SimplyDraft.App.Controls"
        x:Class="SimplyDraft.App.Views.TestWindow"
        x:DataType="vm:TestWindowViewModel"
        Title="File Explorer Test"
        Width="400" Height="600">

    <controls:FileExplorerControl DataContext="{Binding FileExplorerPanel}"/>

</Window>